# LLM provider: deepseek or minimax
LLM_PROVIDER=deepseek

# DeepSeek OpenAI-compatible chat API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Minimax OpenAI-compatible chat API
# Set LLM_PROVIDER=minimax and fill all three values when using Minimax.
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=
MINIMAX_MODEL=

# MySQL
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/literature_review
